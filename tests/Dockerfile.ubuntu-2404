FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        rsync \
        perl \
        libtime-parsedate-perl \
        openssh-server \
        openssh-client \
        btrfs-progs \
        cpanminus \
        make \
        gcc \
        libc6-dev \
    && rm -rf /var/lib/apt/lists/*

RUN cpanm --quiet --notest Time::Period

COPY . /dirvish-src/
RUN sh /dirvish-src/tests/runner/install_dirvish.sh /dirvish-src

COPY tests/runner/ /tests/
RUN chmod +x /tests/*.sh /tests/cases/*.sh

ENTRYPOINT ["/tests/entrypoint.sh"]