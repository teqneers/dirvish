FROM debian:bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
        rsync \
        perl \
        libtime-parsedate-perl \
        openssh-server \
        openssh-client \
        btrfs-progs \
        cpanminus \
        make \
        gcc \
        libc6-dev \
    && rm -rf /var/lib/apt/lists/*

# Time::Period is not packaged for Debian; install via CPAN
RUN cpanm --quiet --notest Time::Period

# Install dirvish from source
COPY . /dirvish-src/
RUN sh /dirvish-src/tests/runner/install_dirvish.sh /dirvish-src

# Copy test runner
COPY tests/runner/ /tests/
RUN chmod +x /tests/*.sh /tests/cases/*.sh

ENTRYPOINT ["/tests/entrypoint.sh"]